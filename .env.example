# ── 必填 ──────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here

# ── 模型配置 ──────────────────────────────────
# 使用 OpenAI 官方：保持默认即可
LLM_MODEL=gpt-4o

# 使用兼容 OpenAI 接口的第三方服务（如 Azure、本地 Ollama、Qwen 等）：
# OPENAI_BASE_URL=https://your-custom-endpoint/v1

# 单页 LLM 调用超时（秒）
PAGE_TIMEOUT=120

# httpx / SDK 层重试次数
MAX_RETRIES=2

# 业务层重试（网络抖动、连接中断、429）
RETRY_ATTEMPTS=4
RETRY_WAIT_MIN=2
RETRY_WAIT_MAX=60
RATE_LIMIT_WAIT=15

# ── PDF 渲染 ──────────────────────────────────
PDF_DPI=150

# ── Web 服务 ──────────────────────────────────
HOST=0.0.0.0
PORT=8000
TASKS_DIR=./tasks
MAX_CONCURRENT_TASKS=3
